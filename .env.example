# Donnit production wiring — placeholders only. Do not commit real secrets.
# The anon (publishable) key is safe for the browser when paired with RLS.

# ---- Server-side (Express) -------------------------------------------------
SUPABASE_PROJECT_ID=bchwrbqaacdijavtugdt
SUPABASE_URL=https://bchwrbqaacdijavtugdt.supabase.co
SUPABASE_ANON_KEY=

# ---- Client-side (Vite) ----------------------------------------------------
# Vite only exposes vars prefixed with VITE_. These are public; never put a
# service role key here.
VITE_SUPABASE_URL=https://bchwrbqaacdijavtugdt.supabase.co
VITE_SUPABASE_ANON_KEY=

# Public URL the password-recovery email should bring users back to.
# Required for any non-localhost deploy: Supabase appends the recovery
# fragment (#access_token=...&type=recovery) to this URL verbatim, and the
# email recipient must be able to reach it from their browser. If unset,
# the client falls back to window.location.origin + pathname, which on
# preview proxies (Perplexity Computer, sites.pplx) or local dev resolves
# to localhost or an internal hostname and breaks the recovery flow with
# ERR_CONNECTION_REFUSED.
#
#   - Production:  https://donnit.ai
#   - Perplexity preview:
#       https://www.perplexity.ai/computer/a/donnit-mvp-preview-_VxG11WdRGCG2xmRPTxflg
#
# Whichever URL is set here MUST also be added to Supabase Authentication →
# URL Configuration → "Redirect URLs" allow-list. Otherwise GoTrue will
# silently rewrite the redirect to the project's Site URL.
VITE_AUTH_REDIRECT_URL=
# Optional generic site URL. Used as a fallback if VITE_AUTH_REDIRECT_URL
# is not set. Same allow-list rule applies in Supabase.
VITE_SITE_URL=

# ---- Integrations / app config --------------------------------------------
GMAIL_CONNECTOR_SOURCE_ID=gcal
REMINDER_CHANNEL_ORDER=in_app,email,push,sms
NODE_ENV=development

# ---- Gmail OAuth (first-party) --------------------------------------------
# Required when running outside the Perplexity Computer preview, where the
# external-tool runtime token may be unreachable from the app process. With
# these set, "Scan email" uses the user's own Gmail OAuth grant to read
# unread Gmail directly.
#
# Setup checklist (see docs/GMAIL_OAUTH.md for the full step-by-step):
#   1. Google Cloud Console -> APIs & Services -> Library -> Enable "Gmail API".
#   2. APIs & Services -> OAuth consent screen -> External, add scope:
#      https://www.googleapis.com/auth/gmail.readonly
#   3. APIs & Services -> Credentials -> Create Credentials -> OAuth client ID
#      -> Application type: "Web application".
#        - Authorized redirect URIs:
#            <your origin>/api/integrations/gmail/oauth/callback
#          e.g. https://donnit.ai/api/integrations/gmail/oauth/callback
#   4. Copy the Client ID + Client secret here. The redirect URI MUST match
#      exactly what Google has registered.
#
# Tokens are stored server-side in donnit.gmail_accounts (RLS-gated by
# auth.uid()). They are NEVER exposed to the browser.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
